# Copy this file to .env and replace values with your own secrets.
# Do not commit .env to source control.

GEMINI_API_KEY=your_new_google_gemini_api_key_here
CLIENT_URL=http://localhost:5173
PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cognivibe_db
DB_USER=root
DB_PASSWORD=password
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
